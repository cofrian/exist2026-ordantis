# Copy this file to `.env` (at the repo root) and fill in your key.
# The .env file is git-ignored and must never be committed.

# Google Gemini API key, used only for the OFFLINE precomputation step
# (src/precompute_gemini.py and src/generate_paraphrases_task23.py).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional overrides:
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_CONCURRENCY=15
